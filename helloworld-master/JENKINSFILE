pipeline {
    agent any

    stages {
        stage('Get Code') {
            steps {
                checkout scm [cite: 75, 76]
            }
        }

        stage('Unit Tests') {
            steps {
                // Ejecuta tests unitarios y genera reporte XML [cite: 78, 91]
                bat 'pytest --junitxml=results.xml'
            }
        }

        stage('Static Analysis (Flake8)') {
            steps {
                // Analiza estilo. Si hay >=8 fallos es unstable, >=10 es unhealthy [cite: 80, 104, 105]
                bat 'flake8 helloworld-master --format=pylint > flake8.log || exit 0'
                recordIssues tools: [flake8(pattern: 'flake8.log')], 
                    unstableTotalAll: 8, failedTotalAll: 10
            }
        }

        stage('Security Test (Bandit)') {
            steps {
                // Analiza seguridad. Si hay >=2 fallos es unstable, >=4 es unhealthy [cite: 81, 110, 111]
                bat 'bandit -r helloworld-master -f txt -o bandit.out || exit 0'
                recordIssues tools: [bandit(pattern: 'bandit.out')], 
                    unstableTotalAll: 2, failedTotalAll: 4
            }
        }

        stage('Coverage') {
            steps {
                // Mide cobertura. Si es <85% es rojo, 85-95% amarillo [cite: 83, 114, 115]
                bat 'coverage run -m pytest helloworld-master/test/unit'
                bat 'coverage xml -o coverage.xml'
                cobertura autoUpdateHealth: false, coberturaReportFile: 'coverage.xml',
                    lineCoverageTargets: '95, 85, 0' 
            }
        }

        stage('Performance') {
            steps {
                // Ejecuta JMeter (asegúrate de que la ruta a jmeter.bat sea la de TU PC) [cite: 82, 126]
                bat 'D:\\apache-jmeter-5.6.3\\bin\\jmeter.bat -n -t test_plan.jmx -l results.jtl'
                perfReport sourceDataFiles: 'results.jtl'
            }
        }
    }

    post {
        always {
            // Publica los resultados de JUnit para la gráfica de evolución [cite: 91, 170]
            junit 'results.xml'
            cleanWs()
        }
    }
}
