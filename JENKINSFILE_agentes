pipeline {
    agent none 

    stages {
        stage('Descarga de Codigo') {
            agent { label 'principal' } 
            steps {
                deleteDir() // Limpia antes de descargar
                checkout scm
                
                bat 'whoami'
                bat 'hostname'
                bat 'echo %WORKSPACE%'
                
                // Aseguramos que guardamos todo lo descargado
                stash includes: '**/*', name: 'codigo_fuente'
            }
        }
        
       stage('Pruebas Unitarias') {
            agent { label 'agente-1' }
            steps {
                deleteDir()
                unstash 'codigo_fuente'
                
                bat 'whoami'
                bat 'hostname'
                
                // Entramos a la carpeta y ejecutamos desde ahí
                bat '''
                    cd helloworld-master
                    set PYTHONPATH=.
                    python -m pytest test/unit
                '''
            }
            post {
                always {
                    cleanWs() 
                }
            }
        }
        
       stage('Pruebas de Integracion') {
            agent { label 'agente-2' }
            steps {
                deleteDir()
                unstash 'codigo_fuente'
                bat 'whoami'
                
                // Usamos PowerShell para lanzar la API de forma persistente
                powershell '''
                    cd helloworld-master
                    $env:PYTHONPATH = "."
                    
                    # Lanzar la API sin bloquear Jenkins
                    Start-Process python -ArgumentList "app/api.py" -WindowStyle Hidden
                    
                    # Esperar a que la API esté lista (15 segundos por seguridad)
                    Start-Sleep -s 15
                    
                    # Ejecutar los tests
                    python -m pytest test/rest
                    
                    # Al terminar, cerramos el proceso de python para no dejar basura
                    Stop-Process -Name "python" -Force -ErrorAction SilentlyContinue
                '''
            }
            post {
                always {
                    cleanWs()
                }
            }
        }
    }
}