pipeline {
    agent none 

    stages {
        stage('Descarga de Codigo') {
            agent { label 'principal' } 
            steps {
                deleteDir() // Limpia antes de descargar
                checkout scm
                
                bat 'whoami'
                bat 'hostname'
                bat 'echo %WORKSPACE%'
                
                // Aseguramos que guardamos todo lo descargado
                stash includes: '**/*', name: 'codigo_fuente'
            }
        }
        
       stage('Pruebas Unitarias') {
            agent { label 'agente-1' }
            steps {
                deleteDir()
                unstash 'codigo_fuente'
                
                bat 'whoami'
                bat 'hostname'
                
                // Entramos a la carpeta y ejecutamos desde ahí
                bat '''
                    cd helloworld-master
                    set PYTHONPATH=.
                    python -m pytest test/unit
                '''
            }
            post {
                always {
                    cleanWs() 
                }
            }
        }
        
       stage('Pruebas de Integracion') {
            agent { label 'agente-2' }
            steps {
                deleteDir()
                unstash 'codigo_fuente'
                
                bat 'whoami'
                bat 'hostname'
                
                // Usamos un comando de Python para esperar, que es más fiable que 'timeout'
                bat '''
                    cd helloworld-master
                    set PYTHONPATH=.
                    
                    :: Lanzar la app y redirigir logs para que no bloquee
                    start /B python app/api.py > app_log.txt 2>&1
                    
                    :: Esperar 10 segundos usando Python (más robusto)
                    python -c "import time; time.sleep(10)"
                    
                    :: Ejecutar los tests
                    python -m pytest test/rest
                '''
            }
            post {
                always {
                    cleanWs()
                }
            }
        }
    }
}