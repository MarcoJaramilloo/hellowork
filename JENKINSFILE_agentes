pipeline {
    // Ponemos "none" arriba porque asignaremos un agente específico a cada etapa
    agent none 

    stages {
        stage('Descarga de Codigo') {
            // Se ejecuta en el nodo principal
            agent { label 'principal' } 
            steps {
                checkout scm
                
                // Evidencia solicitada por la rúbrica
                bat 'whoami'
                bat 'hostname'
                bat 'echo %WORKSPACE%'
                
                // Empaquetamos todo el código fuente y lo llamamos 'codigo_fuente'
                stash includes: '**/*', name: 'codigo_fuente'
            }
        }
        
        stage('Pruebas Unitarias') {
            // Se ejecuta en el primer agente secundario
            agent { label 'agente-1' }
            steps {
                // Desempaquetamos el código que nos pasó el nodo principal
                unstash 'codigo_fuente'
                
                // Evidencia
                bat 'whoami'
                bat 'hostname'
                bat 'echo %WORKSPACE%'
                
                // Aquí va tu comando real para pruebas unitarias. Ejemplo:
                bat 'pytest test/unit'
            }
            post {
                always {
                    // Limpieza del workspace al terminar [cite: 620]
                    cleanWs() 
                }
            }
        }
        
        stage('Pruebas de Integracion') {
            // Se ejecuta en el segundo agente secundario
            agent { label 'agente-2' }
            steps {
                unstash 'codigo_fuente'
                
                // Evidencia
                bat 'whoami'
                bat 'hostname'
                bat 'echo %WORKSPACE%'
                
                // Aquí va tu comando real para pruebas REST. Ejemplo:
                bat 'pytest test/rest'
            }
            post {
                always {
                    cleanWs()
                }
            }
        }
    }
}