pipeline {
    agent none 

    stages {
        stage('Descarga de Codigo') {
            agent { label 'principal' } 
            steps {
                deleteDir() // Limpia antes de descargar
                checkout scm
                
                bat 'whoami'
                bat 'hostname'
                bat 'echo %WORKSPACE%'
                
                // Aseguramos que guardamos todo lo descargado
                stash includes: '**/*', name: 'codigo_fuente'
            }
        }
        
        stage('Pruebas Unitarias') {
            agent { label 'agente-1' }
            steps {
                deleteDir() // Limpia el agente antes de empezar
                unstash 'codigo_fuente'
                
                bat 'whoami'
                bat 'hostname'
                bat 'echo %WORKSPACE%'
                
                // Muestra qué archivos llegaron al agente (diagnóstico)
                bat 'dir' 
                
                // Comando más robusto para ejecutar pytest en Windows
                bat 'python -m pytest test/unit'
            }
            post {
                always {
                    // Mantenemos limpio el workspace al final
                    cleanWs() 
                }
            }
        }
        
        stage('Pruebas de Integracion') {
            agent { label 'agente-2' }
            steps {
                deleteDir()
                unstash 'codigo_fuente'
                
                bat 'whoami'
                bat 'hostname'
                bat 'echo %WORKSPACE%'
                
                bat 'dir'
                
                // Ejecuta las pruebas de la API (Recuerda tener Wiremock en el 9090)
                bat 'python -m pytest test/rest'
            }
            post {
                always {
                    cleanWs()
                }
            }
        }
    }
}