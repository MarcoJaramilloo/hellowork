pipeline {
    agent none

    stages {
        stage('Descarga de Codigo') {
            agent any
            steps {
                checkout scm
                bat '''
                    echo "=== INFO AGENTE: GET CODE ==="
                    whoami
                    hostname
                    echo "Workspace: %WORKSPACE%"
                '''
                stash name: 'codigo', useDefaultExcludes: false
            }
        }

        stage('Pruebas Unitarias') {
            agent { label 'python-agent' }
            steps {
                deleteDir()
                unstash 'codigo'
                bat '''
                    echo "=== INFO AGENTE: UNIT TESTS ==="
                    whoami
                    hostname
                    cd helloworld-master
                    set PYTHONPATH=.
                    python -m pytest test/unit
                '''
            }
            post {
                always {
                    cleanWs()
                }
            }
        }

        stage('Pruebas de Integracion') {
            agent { label 'python-agent' } // Forzamos agente-1 para evitar problemas de red
            steps {
                deleteDir()
                unstash 'codigo'
                // catchError asegura que si falla Wiremock, el pipeline siga avanzando a Coverage
                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    bat '''
                        echo "=== INFO AGENTE: INTEGRATION TESTS ==="
                        whoami
                        cd helloworld-master
                        set PYTHONPATH=.
                        
                        :: Forzar el cierre de cualquier Flask previo para evitar bloqueos de carpetas
                        taskkill /F /IM python.exe /T >NUL 2>&1 || exit 0
                        
                        :: Levantar la API en segundo plano
                        start /B python app/api.py
                        ping 127.0.0.1 -n 15 > nul
                        
                        :: Correr pruebas de integracion
                        python -m pytest test/rest
                    '''
                }
            }
            post {
                always {
                    bat '''
                        :: Forzar cierre del proceso Flask zombi para liberar el Workspace en Windows
                        taskkill /F /IM python.exe /T >NUL 2>&1 || exit 0
                    '''
                    cleanWs()
                }
            }
        }

        stage('Coverage') {
            agent { label 'python-agent' }
            steps {
                deleteDir()
                unstash 'codigo'
                bat '''
                    echo "=== INFO AGENTE: COVERAGE ==="
                    whoami
                    hostname
                    cd helloworld-master
                    set PYTHONPATH=.
                    python -m coverage run -m pytest test/unit
                    python -m coverage xml -o coverage.xml
                '''
                recordCoverage(tools: [[parser: 'COBERTURA', pattern: 'helloworld-master/coverage.xml']])
            }
            post {
                always {
                    cleanWs()
                }
            }
        }
    }
}
