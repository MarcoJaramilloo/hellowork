pipeline {
    agent none

    stages {
        stage('Descarga de Codigo') {
            agent any
            steps {
                checkout scm
                bat '''
                    whoami
                    hostname
                    echo %WORKSPACE%
                '''
                stash name: 'codigo', useDefaultExcludes: false
            }
        }

        stage('Pruebas Unitarias') {
            agent { label 'python-agent' }
            steps {
                deleteDir()
                unstash 'codigo'
                bat '''
                    whoami
                    hostname
                    cd helloworld-master
                    set PYTHONPATH=.
                    python -m pytest test/unit
                '''
            }
            post {
                always {
                    cleanWs()
                }
            }
        }

        stage('Pruebas de Integracion') {
            agent { label 'python-agent' }
            steps {
                // Capturamos el error para que el pipeline continue hacia la etapa de Coverage
                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    deleteDir()
                    unstash 'codigo'
                    bat '''
                        whoami
                        cd helloworld-master
                        set PYTHONPATH=.
                        taskkill /F /IM python.exe /T >NUL 2>&1 || exit 0
                        start /B python app/api.py
                        ping 127.0.0.1 -n 15 > nul
                        python -m pytest test/rest
                    '''
                }
            }
            post {
                always {
                    cleanWs()
                }
            }
        }

        stage('Coverage') {
            agent { label 'python-agent' }
            steps {
                deleteDir()
                unstash 'codigo'
                bat '''
                    whoami
                    hostname
                    cd helloworld-master
                    set PYTHONPATH=.
                    python -m coverage run -m pytest test/unit
                    python -m coverage xml -o coverage.xml
                '''
                // Registramos la cobertura en el Workspace principal
                recordCoverage(tools: [[parser: 'COBERTURA', pattern: 'helloworld-master/coverage.xml']])
            }
            post {
                always {
                    cleanWs()
                }
            }
        }
    }
}
