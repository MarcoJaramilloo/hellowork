pipeline {
    agent none 

    stages {
        stage('Descarga de Codigo') {
            agent { label 'principal' } 
            steps {
                deleteDir() // Limpia antes de descargar
                checkout scm
                
                bat 'whoami'
                bat 'hostname'
                bat 'echo %WORKSPACE%'
                
                // Aseguramos que guardamos todo lo descargado
                stash includes: '**/*', name: 'codigo_fuente'
            }
        }
        
       stage('Pruebas Unitarias') {
            agent { label 'agente-1' }
            steps {
                deleteDir()
                unstash 'codigo_fuente'
                
                bat 'whoami'
                bat 'hostname'
                
                // Entramos a la carpeta y ejecutamos desde ahí
                bat '''
                    cd helloworld-master
                    set PYTHONPATH=.
                    python -m pytest test/unit
                '''
            }
            post {
                always {
                    cleanWs() 
                }
            }
        }
        
       stage('Pruebas de Integracion') {
            agent { label 'agente-2' }
            steps {
                deleteDir()
                unstash 'codigo_fuente'
                
                bat 'whoami'
                
                bat '''
                    cd helloworld-master
                    set PYTHONPATH=.
                    
                    :: Forzar el cierre de cualquier python previo para liberar el puerto 5000
                    taskkill /F /IM python.exe /T > NUL 2>&1
                    
                    :: Lanzar la API
                    start /B python app/api.py
                    
                    :: Esperar 15 segundos reales usando un ping al localhost (truco de Windows)
                    ping 127.0.0.1 -n 15 > nul
                    
                    :: Ejecutar los tests
                    python -m pytest test/rest
                '''
            }
            post {
                always {
                    cleanWs()
                }
            }
        }
    }
}