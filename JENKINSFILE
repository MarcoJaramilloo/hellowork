pipeline {
    agent any

    stages {
        stage('Get Code') {
            steps {
                checkout scm
            }
        }

        stage('Tests') {
            parallel {
                stage('Unit') {
                    steps {
                        bat 'set PYTHONPATH=%WORKSPACE%\\helloworld-master && python -m pytest --junitxml=result-unit.xml helloworld-master/test/unit'
                    }
                }
                stage('Rest') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            bat '''
                                set FLASK_APP=helloworld-master\\app\\api.py
                                start /B python -m flask run
                                
                                :: Intento de arranque de Wiremock - Verifica que el archivo exista en esta ruta
                                if exist "C:\\Unir\\Ejercicios\\wiremock\\wiremock-jre8-standalone-2.28.0.jar" (
                                    start /B java -jar "C:\\Unir\\Ejercicios\\wiremock\\wiremock-jre8-standalone-2.28.0.jar" --port 9090 --root-dir helloworld-master\\test\\wiremock
                                ) else (
                                    echo "ADVERTENCIA: No se encontro el archivo JAR de Wiremock"
                                )
                                
                                ping 127.0.0.1 -n 15 > nul
                                
                                set PYTHONPATH=%WORKSPACE%\\helloworld-master
                                python -m pytest --junitxml=result-rest.xml helloworld-master/test/rest
                            '''
                        }
                    }
                }
            }
        }

        stage('Static Analysis (Flake8)') {
            steps {
                // Usamos python -m para invocar flake8
                bat 'python -m flake8 helloworld-master/app --format=pylint > flake8.log || exit 0'
                recordIssues tools: [flake8(pattern: 'flake8.log')], 
                    qualityGates: [
                        [threshold: 8, type: 'TOTAL'],
                        [threshold: 10, type: 'TOTAL']
                    ]
            }
        }

        stage('Security Test (Bandit)') {
            steps {
                // Usamos python -m para invocar bandit y quitamos el metodo problematico
                bat 'python -m bandit -r helloworld-master/app -f txt -o bandit.out || exit 0'
                echo "Analisis de Bandit finalizado. Revisar bandit.out para detalles."
            }
        }

        stage('Coverage') {
            steps {
                bat 'set PYTHONPATH=%WORKSPACE%\\helloworld-master && python -m coverage run -m pytest helloworld-master/test/unit'
                bat 'python -m coverage xml -o coverage.xml'
                cobertura autoUpdateHealth: false, coberturaReportFile: 'coverage.xml',
                    lineCoverageTargets: '95, 85, 0' 
            }
        }

        stage('Performance') {
            steps {
                bat 'D:\\apache-jmeter-5.6.3\\bin\\jmeter.bat -n -t test_plan.jmx -l results.jtl'
                perfReport sourceDataFiles: 'results.jtl'
            }
        }
    }

    post {
        always {
            junit 'result-unit.xml'
            // No borramos el workspace inmediatamente para evitar el error de acceso denegado
            echo "Pipeline finalizado."
        }
    }
}
